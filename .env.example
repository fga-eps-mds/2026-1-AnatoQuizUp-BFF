NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# URLs dos servicos downstream
BACKEND_URL=http://localhost:3333
AI_URL=

# Segredo compartilhado com Backend e AI (gerar com: openssl rand -hex 32)
INTERNAL_TOKEN=

# JWT - mesmo segredo usado pelo Backend
JWT_SECRET_KEY=

# CORS - origens publicas que podem consumir o BFF
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Timeout (ms) para chamadas ao Backend e AI
REQUEST_TIMEOUT_MS=15000
