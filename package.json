{
  "name": "anatoquizup-bff",
  "version": "1.0.0",
  "description": "Backend-For-Frontend of the AnatoQuizUp project.",
  "private": true,
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/server.ts",
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "test:ci": "jest --coverage --runInBand",
    "format": "prettier . --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fga-eps-mds/2026-1-AnatoQuizUp-BFF.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "bff",
    "backend-for-frontend"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/fga-eps-mds/2026-1-AnatoQuizUp-BFF/issues"
  },
  "homepage": "https://github.com/fga-eps-mds/2026-1-AnatoQuizUp-BFF#readme",
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.8.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.6.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
